# Copy this to .env and fill in your API key
# ─────────────────────────────────────────────

# LLM Provider: "anthropic" (default), "openai", or "gemini"
LLM_PROVIDER=anthropic

# Gemini — only needed if LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic (Claude Sonnet) — only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (GPT-4o) — only needed if LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here

# Guardrail settings (optional overrides)
MAX_ROWS=1000
QUERY_TIMEOUT_SECONDS=30
